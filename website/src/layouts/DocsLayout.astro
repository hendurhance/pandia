---
import Layout from './Layout.astro';
import Nav from '../components/home/Nav.astro';

interface Props {
  title: string;
  description?: string;
  currentDoc?: string;
}
const { title, description, currentDoc = '/docs' } = Astro.props;

const docsNav = [
  { category: 'Getting started', items: [
    { title: 'Introduction', href: '/docs' },
    { title: 'Installation', href: '/docs/installation' },
    { title: 'Quick start', href: '/docs/quick-start' },
  ]},
  { category: 'The workbench', items: [
    { title: 'Views', href: '/docs/views' },
    { title: 'Editing', href: '/docs/editor' },
  ]},
  { category: 'Working with data', items: [
    { title: 'Import & auto-detect', href: '/docs/import-export' },
    { title: 'Type generation', href: '/docs/type-generation' },
    { title: 'Compare & diff', href: '/docs/compare' },
    { title: 'Validate', href: '/docs/validate' },
    { title: 'Repair', href: '/docs/repair' },
    { title: 'Search & replace', href: '/docs/search' },
    { title: 'Export', href: '/docs/export' },
  ]},
  { category: 'Reference', items: [
    { title: 'Large files', href: '/docs/performance' },
    { title: 'Themes & appearance', href: '/docs/themes' },
    { title: 'Keyboard shortcuts', href: '/docs/shortcuts' },
    { title: 'Settings', href: '/docs/configuration' },
    { title: 'Troubleshooting', href: '/docs/troubleshooting' },
  ]},
];

const norm = (s: string) => '/' + s.replace(/^\/+|\/+$/g, '');
const cur = norm(currentDoc);
const flat = docsNav.flatMap((s) => s.items);
const idx = flat.findIndex((i) => norm(i.href) === cur);
const prev = idx > 0 ? flat[idx - 1] : null;
const next = idx >= 0 && idx < flat.length - 1 ? flat[idx + 1] : null;
const canonical = cur;
---
<Layout title={title} description={description} canonical={canonical} type="article">
  <div class="pandia-page docs-page">
    <div class="spine"></div>
    <Nav />
    <div class="docs-shell">
      <aside class="docs-side" id="docsSide" aria-label="Documentation">
        <div class="docs-side-head">
          <span>Docs</span>
          <button class="docs-side-close" id="docsSideClose" aria-label="Close" type="button">✕</button>
        </div>
        <nav class="docs-nav">
          {docsNav.map((sec) => (
            <div class="docs-nav-group">
              <div class="docs-nav-cat">{sec.category}</div>
              <ul>
                {sec.items.map((it) => (
                  <li><a href={it.href} class={norm(it.href) === cur ? 'on' : ''} aria-current={norm(it.href) === cur ? 'page' : undefined}>{it.title}</a></li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      </aside>

      <main class="docs-main">
        <article class="docs-prose">
          <slot />
        </article>
        <nav class="docs-pn">
          {prev ? <a class="docs-pn-a prev" href={prev.href}><span>← Previous</span><b>{prev.title}</b></a> : <span></span>}
          {next ? <a class="docs-pn-a next" href={next.href}><span>Next →</span><b>{next.title}</b></a> : <span></span>}
        </nav>
        <footer class="docs-foot">
          <span>© 2026 Pandia · Apache-2.0</span>
          <span class="docs-foot-links">
            <a href="/">Home</a>
            <a href="/download">Download</a>
            <a href="/changelog">Changelog</a>
            <a href="https://github.com/hendurhance/pandia" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
          </span>
        </footer>
      </main>

      <aside class="docs-toc" aria-label="On this page">
        <div class="docs-toc-label">On this page</div>
        <nav id="docsToc"></nav>
      </aside>
    </div>

    <button class="docs-side-toggle" id="docsSideToggle" aria-label="Open docs menu" type="button">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      Menu
    </button>
    <div class="docs-side-scrim" id="docsSideScrim"></div>
  </div>

  <style is:global>
    .pandia-page.docs-page .docs-shell {
      max-width: 1320px; margin: 0 auto;
      display: grid; grid-template-columns: 256px minmax(0, 1fr) 220px; gap: 0;
      align-items: start;
    }
    .pandia-page.docs-page .docs-side {
      position: sticky; top: 62px; align-self: start; max-height: calc(100vh - 62px);
      overflow-y: auto; border-right: 1px solid var(--page-rule); padding: 28px 24px 40px; background: var(--page-bg);
    }
    .pandia-page.docs-page .docs-side-head { display: none; }
    .pandia-page.docs-page .docs-nav-group + .docs-nav-group { margin-top: 26px; }
    .pandia-page.docs-page .docs-nav-cat {
      font-family: var(--mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--page-faint); margin-bottom: 10px;
    }
    .pandia-page.docs-page .docs-nav ul { list-style: none; display: flex; flex-direction: column; }
    .pandia-page.docs-page .docs-nav a {
      display: block; font-family: var(--mono); font-size: 13px; color: var(--page-dim);
      padding: 6px 12px; transition: color var(--dur) var(--ease);
    }
    .pandia-page.docs-page .docs-nav a:hover { color: var(--page-text); }
    .pandia-page.docs-page .docs-nav a.on { color: var(--accent); background: var(--accent-soft); }
    .pandia-page.docs-page .docs-gh { display: block; margin-top: 28px; padding-top: 20px; border-top: 1px solid var(--page-rule); font-family: var(--mono); font-size: 12px; color: var(--page-faint); }
    .pandia-page.docs-page .docs-gh:hover { color: var(--page-text); }

    .pandia-page.docs-page .docs-main { min-width: 0; display: flex; flex-direction: column; padding: 0 56px; }
    .pandia-page.docs-page .docs-prose { padding: 52px 0 8px; min-height: 60vh; }

    .pandia-page.docs-page .docs-pn { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 48px 0 0; }
    .pandia-page.docs-page .docs-pn-a { display: flex; flex-direction: column; gap: 5px; padding: 16px 18px; border: 1px solid var(--page-rule); transition: border-color var(--dur) var(--ease); }
    .pandia-page.docs-page .docs-pn-a.next { text-align: right; }
    .pandia-page.docs-page .docs-pn-a:hover { border-color: var(--accent-line); }
    .pandia-page.docs-page .docs-pn-a span { font-family: var(--mono); font-size: 11px; color: var(--page-faint); }
    .pandia-page.docs-page .docs-pn-a b { font-family: var(--disp); font-size: 15px; font-weight: 600; color: var(--page-text); }

    .pandia-page.docs-page .docs-foot {
      display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;
      margin-top: 40px; padding: 22px 0 56px; border-top: 1px solid var(--page-rule);
      font-family: var(--mono); font-size: 12px; color: var(--page-faint); letter-spacing: 0.02em;
    }
    .pandia-page.docs-page .docs-foot-links { display: flex; gap: 18px; flex-wrap: wrap; }
    .pandia-page.docs-page .docs-foot a { color: var(--page-dim); }
    .pandia-page.docs-page .docs-foot a:hover { color: var(--page-text); }

    .pandia-page.docs-page .docs-toc { position: sticky; top: 62px; align-self: start; max-height: calc(100vh - 62px); overflow-y: auto; padding: 52px 24px 40px 8px; }
    .pandia-page.docs-page .docs-toc-label { font-family: var(--mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--page-faint); margin-bottom: 12px; }
    .pandia-page.docs-page .docs-toc a { display: block; font-family: var(--mono); font-size: 12px; color: var(--page-dim); padding: 5px 0 5px 12px; border-left: 1px solid var(--page-rule); line-height: 1.4; }
    .pandia-page.docs-page .docs-toc a:hover { color: var(--page-text); }
    .pandia-page.docs-page .docs-toc a.h3 { padding-left: 24px; font-size: 11.5px; }
    .pandia-page.docs-page .docs-toc a.active { color: var(--accent); border-left-color: var(--accent); }

    .pandia-page.docs-page .docs-side-toggle {
      display: none; position: fixed; bottom: 20px; left: 20px; z-index: 90;
      align-items: center; gap: 8px; padding: 10px 16px; background: var(--accent); color: #1b0e07;
      font-family: var(--mono); font-size: 12.5px; font-weight: 600; border: 0; cursor: pointer;
      box-shadow: 0 8px 24px -8px rgba(255,106,58,0.6);
    }
    .pandia-page.docs-page .docs-side-scrim { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 95; }

    @media (max-width: 1100px) {
      .pandia-page.docs-page .docs-shell { grid-template-columns: 240px minmax(0,1fr); }
      .pandia-page.docs-page .docs-toc { display: none; }
      .pandia-page.docs-page .docs-main { padding: 0 36px; }
    }
    @media (max-width: 860px) {
      .pandia-page.docs-page .docs-shell { grid-template-columns: 1fr; }
      .pandia-page.docs-page .docs-main { padding: 0 24px; }
      .pandia-page.docs-page .docs-side {
        position: fixed; top: 0; bottom: 0; left: 0; width: 300px; max-width: 84vw; height: 100vh; z-index: 100;
        transform: translateX(-100%); transition: transform 240ms var(--ease); border-right: 1px solid var(--page-rule);
        padding-top: 20px;
      }
      .pandia-page.docs-page.side-open .docs-side { transform: none; }
      .pandia-page.docs-page.side-open .docs-side-scrim { display: block; }
      .pandia-page.docs-page .docs-side-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--page-faint); }
      .pandia-page.docs-page .docs-side-close { background: 0; border: 0; color: var(--page-dim); font-size: 16px; cursor: pointer; }
      .pandia-page.docs-page .docs-side-toggle { display: flex; }
      .pandia-page.docs-page .docs-pn { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    const page = document.querySelector('.docs-page');
    const open = () => page?.classList.add('side-open');
    const close = () => page?.classList.remove('side-open');
    document.getElementById('docsSideToggle')?.addEventListener('click', open);
    document.getElementById('docsSideClose')?.addEventListener('click', close);
    document.getElementById('docsSideScrim')?.addEventListener('click', close);
    document.querySelectorAll('.docs-side a').forEach((a) => a.addEventListener('click', close));

    const prose = document.querySelector('.docs-prose');
    const toc = document.getElementById('docsToc');
    if (prose && toc) {
      const heads = prose.querySelectorAll('h2, h3');
      const slug = (t: string) => t.toLowerCase().trim().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-');
      const links: HTMLAnchorElement[] = [];
      heads.forEach((h) => {
        const el = h as HTMLElement;
        if (!el.id) el.id = slug(el.textContent || '');
        const a = document.createElement('a');
        a.href = '#' + el.id;
        a.textContent = el.textContent;
        if (el.tagName === 'H3') a.className = 'h3';
        toc.appendChild(a);
        links.push(a);
      });
      if (!links.length) { const t = toc.closest('.docs-toc') as HTMLElement | null; if (t) t.style.display = 'none'; }
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            links.forEach((l) => l.classList.toggle('active', l.getAttribute('href') === '#' + e.target.id));
          }
        });
      }, { rootMargin: '0px 0px -75% 0px' });
      heads.forEach((h) => io.observe(h));
    }
  </script>
</Layout>
