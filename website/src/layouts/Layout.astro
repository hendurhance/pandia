---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  noindex?: boolean;
  structuredData?: object[];
}

const {
  title,
  description = 'Pandia is a fast, native JSON workbench for macOS, Windows and Linux. Open any file instantly — even multi-gigabyte — read it five ways, generate types for 9 languages, compare, validate, repair and export. Offline, private, free and open source.',
  canonical,
  image = '/og-image.png',
  type = 'website',
  publishedTime,
  modifiedTime,
  noindex = false,
  structuredData = [],
} = Astro.props;

const siteUrl = 'https://www.pandia.app';
// Canonical: www host, https, NO trailing slash (matches trailingSlash: 'never'); root stays "/".
const rawPath = canonical ?? Astro.url.pathname;
const canonicalPath = rawPath.replace(/\/+$/, ''); // '' for root → bare https://www.pandia.app
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const imageUrl = image.startsWith('http') ? image : `${siteUrl}${image}`;
// A title that already leads with "Pandia —" (the homepage) skips the "| Pandia" suffix.
const fullTitle = title.startsWith('Pandia —') ? title : `${title} | Pandia`;

const orgId = `${siteUrl}/#organization`;
const websiteId = `${siteUrl}/#website`;
const productDescription = 'Pandia is a fast, native JSON workbench for macOS, Windows and Linux. Open any file instantly — even multi-gigabyte — read it five ways, generate types for 9 languages, compare, validate, repair and export. Offline, private, free and open source.';

const jsonLdGraph = [
  {
    '@type': 'Organization',
    '@id': orgId,
    name: 'Pandia',
    url: siteUrl,
    logo: { '@type': 'ImageObject', url: `${siteUrl}/favicon-192x192.png`, width: 192, height: 192 },
    sameAs: [
      'https://github.com/hendurhance/pandia',
      'https://x.com/PandiaApp',
    ],
  },
  {
    '@type': 'WebSite',
    '@id': websiteId,
    name: 'Pandia',
    url: siteUrl,
    description: productDescription,
    publisher: { '@id': orgId },
    inLanguage: 'en',
  },
  {
    '@type': 'SoftwareApplication',
    '@id': `${siteUrl}/#software`,
    name: 'Pandia',
    description: productDescription,
    url: siteUrl,
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'macOS, Windows, Linux',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    publisher: { '@id': orgId },
    author: { '@type': 'Person', name: 'hendurhance', url: 'https://github.com/hendurhance' },
    license: 'https://www.apache.org/licenses/LICENSE-2.0',
    downloadUrl: 'https://github.com/hendurhance/pandia/releases/latest',
    softwareVersion: '1.0.0',
    screenshot: `${siteUrl}/og-image.png`,
    featureList: [
      'Open multi-gigabyte JSON files instantly',
      'Five views: Tree, Code, Grid, Graph and Compare',
      'Generate types for TypeScript, Rust, Go, Kotlin, Python, PHP, Java, Zod and JSON Schema',
      'JSON diff and compare',
      'JSON Schema validation',
      'JSON repair',
      'Import and auto-detect JSON, YAML, XML, CSV and cURL',
      'Export JSON, YAML, CSV and XML',
      'Offline and private — no accounts, no telemetry',
    ],
  },
  ...structuredData,
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="keywords" content="JSON workbench, JSON viewer, JSON editor, JSON tree viewer, large JSON viewer, multi-gigabyte JSON, JSON to TypeScript, JSON to Rust, JSON to Go, type generation, JSON diff, JSON compare, JSON repair, JSON Schema validation, JSON to YAML, JSON to CSV, JSON to XML, native app, Tauri, Rust, offline, open source, developer tools" />
    <meta name="author" content="hendurhance" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Pandia — the native JSON workbench" />
    <meta property="og:site_name" content="Pandia" />
    <meta property="og:locale" content="en_US" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content="Pandia — the native JSON workbench" />
    <meta name="twitter:creator" content="@PandiaApp" />

    <meta name="application-name" content="Pandia" />
    <meta name="apple-mobile-web-app-title" content="Pandia" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#1b1b1d" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#FBF8F2" />
    <meta name="msapplication-TileColor" content="#1b1b1d" />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />

    <script is:inline>
      if (history.scrollRestoration) {
        history.scrollRestoration = 'manual';
      }
      window.scrollTo(0, 0);
    </script>

    <script type="application/ld+json" set:html={JSON.stringify({ '@context': 'https://schema.org', '@graph': jsonLdGraph })} />
  </head>
  <body>
    <slot />
    <script>
      // Sitewide reveal for .iv elements (home sections + landing pages). No-op on pages without them.
      const ivObserver = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('shown'); ivObserver.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      document.querySelectorAll('.iv').forEach((el) => ivObserver.observe(el));
    </script>
  </body>
</html>
