---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/home/Nav.astro';
import Footer from '../components/home/Footer.astro';
import { REPO, RELEASES } from '../data/site';
import { releases } from '../data/releases';
---
<Layout
  title="Changelog"
  description="Pandia changelog — every release, what changed. A free, native JSON workbench for macOS, Windows and Linux."
  canonical="/changelog"
  type="article"
>
  <div class="pandia-page cl-page">
    <div class="spine"></div>
    <Nav />
    <main>
      <section class="block cl-top">
        <div class="wrap cl-top-in">
          <span class="eyebrow"><span class="tick"></span>Changelog</span>
          <h1>What's <em>new</em>.</h1>
          <p>Every Pandia release and what changed. Want the latest build? Head to the
          <a href="/download">download page</a>.</p>
          <div class="cl-cta">
            <a class="btn btn-ghost" href={RELEASES} target="_blank" rel="noopener noreferrer">Watch releases on GitHub</a>
          </div>
        </div>
      </section>

      <section class="block cl-list">
        <div class="wrap">
          {releases.map((r) => (
            <article class="cl-rel">
              <div class="cl-meta">
                <div class="cl-ver">v{r.version}</div>
                {r.tag && <span class={`cl-tag ${r.tagKind}`}>{r.tag}</span>}
                <time class="cl-date">{r.date}</time>
                <a class="cl-link" href={`${RELEASES}/tag/v${r.version}`} target="_blank" rel="noopener noreferrer">Release notes ↗</a>
              </div>
              <div class="cl-body">
                {r.groups.map((g) => (
                  <div class="cl-group">
                    <h2 class="cl-group-label">{g.label}</h2>
                    <ul class="cl-changes">
                      {g.items.map((it) => <li>{it}</li>)}
                    </ul>
                  </div>
                ))}
              </div>
            </article>
          ))}

          <p class="cl-foot">More on the way. Watch the repo on
          <a href={REPO} target="_blank" rel="noopener noreferrer">GitHub</a> to follow along.</p>
        </div>
      </section>
    </main>
    <Footer />
  </div>

  <style is:global>
    .pandia-page.cl-page .cl-top { padding: 84px 0 40px; }
    .pandia-page.cl-page .cl-top-in { max-width: 760px; }
    .pandia-page.cl-page .cl-top h1 {
      font-family: var(--disp); font-size: clamp(42px, 6vw, 72px); font-weight: 700;
      letter-spacing: -0.035em; line-height: 0.98; margin-top: 16px; color: var(--page-text);
    }
    .pandia-page.cl-page .cl-top h1 em { font-style: normal; color: var(--accent); }
    .pandia-page.cl-page .cl-top p {
      font-family: var(--disp); font-size: clamp(16px, 1.6vw, 19px); color: var(--page-dim);
      max-width: 58ch; margin: 20px 0 0; line-height: 1.6;
    }
    .pandia-page.cl-page .cl-top p a { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }
    .pandia-page.cl-page .cl-cta { margin-top: 28px; }

    .pandia-page.cl-page .cl-list { padding-top: 8px; }
    .pandia-page.cl-page .cl-rel {
      display: grid; grid-template-columns: 210px 1fr; gap: 48px;
      padding: 48px 0; border-top: 1px solid var(--page-rule);
    }
    .pandia-page.cl-page .cl-meta { position: relative; }
    .pandia-page.cl-page .cl-ver { font-family: var(--disp); font-size: 30px; font-weight: 700; letter-spacing: -0.03em; color: var(--page-text); }
    .pandia-page.cl-page .cl-tag {
      display: inline-block; margin-top: 10px; font-family: var(--mono); font-size: 10px;
      letter-spacing: 0.12em; text-transform: uppercase; padding: 3px 9px; border: 1px solid var(--accent-line);
      color: var(--accent); background: var(--accent-soft);
    }
    .pandia-page.cl-page .cl-tag.stable { color: var(--green); border-color: var(--green); background: transparent; }
    .pandia-page.cl-page .cl-date { display: block; margin-top: 14px; font-family: var(--mono); font-size: 12px; color: var(--page-faint); letter-spacing: 0.03em; }
    .pandia-page.cl-page .cl-link { display: inline-block; margin-top: 10px; font-family: var(--mono); font-size: 12px; color: var(--page-dim); }
    .pandia-page.cl-page .cl-link:hover { color: var(--accent); }

    .pandia-page.cl-page .cl-group + .cl-group { margin-top: 26px; }
    .pandia-page.cl-page .cl-group-label {
      font-family: var(--mono); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--page-faint); margin-bottom: 4px;
    }
    .pandia-page.cl-page .cl-changes { list-style: none; display: flex; flex-direction: column; }
    .pandia-page.cl-page .cl-changes li {
      font-family: var(--disp); font-size: 15.5px; color: var(--page-dim); line-height: 1.5;
      padding: 12px 0 12px 22px; border-top: 1px solid var(--page-rule); position: relative;
    }
    .pandia-page.cl-page .cl-changes li:first-child { border-top: 0; }
    .pandia-page.cl-page .cl-changes li::before { content: ""; position: absolute; left: 0; top: 19px; width: 7px; height: 1.5px; background: var(--accent); }

    .pandia-page.cl-page .cl-foot {
      margin-top: 12px; padding-top: 32px; border-top: 1px solid var(--page-rule);
      font-family: var(--mono); font-size: 12.5px; color: var(--page-faint);
    }
    .pandia-page.cl-page .cl-foot a { color: var(--page-dim); text-decoration: underline; text-underline-offset: 2px; }
    .pandia-page.cl-page .cl-foot a:hover { color: var(--page-text); }

    @media (max-width: 760px) {
      .pandia-page.cl-page .cl-rel { grid-template-columns: 1fr; gap: 18px; }
    }
  </style>
</Layout>
